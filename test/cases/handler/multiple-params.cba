-- @expect-type: (Int * Bool)!{}
-- @expect-value: Pure: (1, True)
-- A single handle can instantiate several parameters at once, given as a
-- comma-separated list [$p -> Int, $q -> Bool].
with handler {
  return x -> return x,
  getp a k -> k 1,
  getq a k -> k true
} [$p -> Int, $q -> Bool] handle (
  effect !getp : Unit ~> $p.
  effect !getq : Unit ~> $q.
  do x <- !getp () in
  do y <- !getq () in
  return (x, y)
)
