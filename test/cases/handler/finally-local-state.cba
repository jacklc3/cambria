-- @expect-type: Int!{ fresh : Unit ~> Name }
with handler {
  return x     -> return (fun _ -> return x),
  get a k      -> return (fun s -> k (s a) s),
  set (b, v) k -> return (fun s -> k () (fun a -> if a == b then return v else s a)),
  ref x k      -> do a <- !fresh () in return (fun s ->
                    k a (fun b -> if b == a then return x else s b)),
  finally s -> s (fun _ -> return 0)
} handle (
  do a <- !ref 2 in
  do b <- !ref 3 in
  (!set (a, !get b + !get a); !get a)
)
