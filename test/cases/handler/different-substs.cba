-- @expect-type: (Int * Bool)!{}
-- @expect-value: Pure: (7, True)
-- Parameter instantiations live on the `with`, not inside the handler, so one
-- handler value can be applied at different instantiations. Here `h` is used
-- once at [$p -> Int] and once at [$p -> Bool].
do h <- return (handler {
  return x -> return x,
  cell a k -> k a
}) in
do i <- with [$p -> Int] h handle (
  effect !cell : Int ~> $p.
  !cell 7
) in
do b <- with [$p -> Bool] h handle (
  effect !cell : Bool ~> $p.
  !cell true
) in
return (i, b)
