-- @expect-type: (List Int * List Bool)!{ fresh : Unit ~> Name }
with handler {
  return x  -> return (fun _ -> return x),
  get a k -> return (fun s -> k (lookup (a, s)) s),
  set x k -> return (fun s -> k () (insert (x, s))),
  ref x k -> do a <- !fresh () in return (fun s ->
    k a (insert (((a, x), s)))),
  finally s -> s empty
} [$p -> Name] handle (
  effect !get : $p ~> Int.
  effect !set : $p * Int ~> Unit.
  effect !ref : Int ~> $p.
  do map <- return (rec map f xs ->
    case uncons xs of {
      inl _       -> return [],
      inr (x,xs') -> f x :: map f xs'
    })
  in
  do refs <- map (fun n -> !ref n) (10 :: 20 :: 30 :: []) in
  do vals <- map (fun r -> !get r) refs in
  do checks <- map (fun n -> return (n == 20)) vals in
  return (vals, checks)
)
