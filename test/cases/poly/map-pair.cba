-- @expect-type: ((Int * Int) * (Int * (Int * Int)))!{ fresh : Unit ~> Name }
with handler {
  $p -> Name,
  return x  -> return (fun _ -> return x),
  get a k -> return (fun s -> k (lookup (a, s)) s),
  set x k -> return (fun s -> k () (insert (x, s))),
  ref x k -> do a <- !fresh () in return (fun s ->
    k a (insert (((a, x), s)))),
  finally s -> s empty
} handle (
  effect !get : $p ~> Int.
  effect !set : $p * Int ~> Unit.
  effect !ref : Int ~> $p.
  do map_pair <- return (fun f (x,y) -> return (f x, f y)) in
  do doubled <- map_pair (fun n -> return (n * 2)) (3, 7) in
  do a <- !ref 100 in
  do b <- !ref 200 in
  do vals <- map_pair (fun r -> !get r) (a, b) in
  do sum <- return (fst vals + snd vals) in
  do new_refs <- map_pair (fun n -> !ref n) (sum, fst doubled + snd doubled) in
  return (doubled, (sum, (!get (fst new_refs), !get (snd new_refs))))
)
