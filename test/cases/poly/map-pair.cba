-- @expect-type: ((Int * Int) * (Int * (Int * Int)))!{ fresh : Unit ~> Name }
with [$p -> Name] handler {
  return x  -> return (fun _ -> return x),
  get a k -> return (fun s -> k (lookup (a, s)) s),
  set x k -> return (fun s -> k () (insert (x, s))),
  ref x k -> do a <- !fresh () in return (fun s ->
    k a (insert (((a, x), s)))),
  finally s -> s empty
} handle (
  effect !get : $p ~> Int.
  effect !set : $p * Int ~> Unit.
  effect !ref : Int ~> $p.
  do map_pair <- return (fun f (x, y) -> return (f x, f y)) in
  do (d1, d2) <- map_pair (fun n -> return (n * 2)) (3, 7) in
  do a <- !ref 100 in
  do b <- !ref 200 in
  do (v1, v2) <- map_pair (fun r -> !get r) (a, b) in
  do sum <- return (v1 + v2) in
  do (r1, r2) <- map_pair (fun n -> !ref n) (sum, d1 + d2) in
  return ((d1, d2), (sum, (!get r1, !get r2)))
)
