-- Real number implementation of Beta/Bernoulli, without state
-- Equivalent to polya.cba
with handler {
  $urn -> Double,
  newurn _ k -> k (!uniform ()),
  sample p k -> k (!bernoulli p)
} handle (
  effect !newurn : Unit ~> $urn.
  effect !sample : $urn ~> Bool.
  do urn <- !newurn () in
  do b1 <- !sample urn in
  do b2 <- !sample urn in
  return (b1, b2)
)
