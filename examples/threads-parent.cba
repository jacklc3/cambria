with handler {
  $name -> Int,
  return x   -> return (fun _ -> return x),
  fresh _ k  -> return (fun n -> k n (n+1)),
  eq (a,b) k -> k (a == b),
  finally f  -> f 0
} handle (
with handler {
  $loc -> $name,
  return x    -> return (fun _ -> return x),
  get a k     -> return (fun s -> k (s a) s),
  set (a,x) k -> return (fun s -> k () (fun b -> if !eq (a, b) then return x else s b)),
  ref x k     -> do a <- !fresh () in return (fun s ->
                   k a (fun b -> if !eq (a, b) then return x else s b)),
  finally s   -> s (fun _ -> return false)
} handle (
  effect !get : $loc ~> Bool.
  effect !set : $loc * Bool ~> Unit.
  effect !ref : Bool ~> $loc.

  with handler {
    $tid -> Unit -> Unit!{...},
    return _ -> return (),
    act  s k -> !print s ; k (),
    wait t k -> t () ; k (),
    stop _ k -> return (),
    fork _ k ->
      do called <- !ref false in
      do thunk <- return (fun _ -> if !get called then return ()
        else ( !set (called, true) ; k (inr ()) )) in
      ( k (inl thunk) ; thunk () )
  } handle (
    effect !fork : Unit ~> $tid + Unit.
    effect !wait : $tid ~> Unit.
    effect !act  : Str ~> Unit.
    effect !stop : Unit ~> Void.

    case !fork () of {
      inl a1 -> case !fork () of {
        inl a2 -> case !fork () of {
          inl a3 -> !wait a2 ; !act "Action 4" ; !stop (),
          inr _  -> !wait a1 ; !wait a2 ; !act "Action 3" ; !stop () },
        inr _  -> !act "Action 2" ; !stop () },
      inr _ -> !act "Action 1" ; !stop () }
  )
))
