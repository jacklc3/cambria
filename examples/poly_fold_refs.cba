-- Polymorphic map over abstract references
--
-- map is a genuinely polymorphic recursive function:
--   forall a b. (a -> b!S) -> List(a) -> List(b)!S
--
-- We instantiate it at three different type pairs:
--
--   1. a=Int, b=$loc   -- allocate a ref for each integer in a list
--   2. a=$loc,  b=Int  -- read from each abstract ref in a list
--   3. a=Int, b=Bool   -- test each integer against a predicate
--
-- The key: in (1) the output list has element type $loc, the abstract
-- parameter. In (2) the *input* list has element type $loc. The same
-- polymorphic map works uniformly, never inspecting what $loc is.
-- The function-encoded local state (as in local_state.cba) instantiates
-- $loc, but map doesn't know or care.

with handler {
  $name -> Int,
  return x   -> return (fun _ -> return x),
  fresh _ k  -> return (fun n -> k n (n+1)),
  eq (a,b) k -> k (a == b),
  finally f  -> f 0
} handle (
with handler {
  $loc -> $name,
  return x    -> return (fun _ -> return x),
  get a k     -> return (fun s -> k (s a) s),
  set (a,x) k -> return (fun s -> k () (fun b -> if !eq (a, b) then return x else s b)),
  ref x k     -> do a <- !fresh () in return (fun s ->
                   k a (fun b -> if !eq (a, b) then return x else s b)),
  finally s   -> s (fun _ -> return 0)
} handle (
  effect !ref : Int ~> $loc.
  effect !get : $loc ~> Int.
  effect !set : $loc * Int ~> Unit.

  -- Polymorphic map: forall a b. (a -> b!S) -> List(a) -> List(b)!S
  do map <- return (rec map f xs ->
    case uncons xs of {
      inl _        -> return [],
      inr (x, xs') -> f x :: map f xs'
    })
  in

  -- (1) map at (Int -> $loc): allocate a ref for each number
  do refs <- map (fun n -> !ref n) (10 :: 20 :: 30 :: []) in

  -- (2) map at ($loc -> Int): read all refs in the list
  do vals <- map (fun r -> !get r) refs in

  -- (3) map at (Int -> Bool): test each value
  do checks <- map (fun n -> !get n == 20) refs in

  return checks
))
