with handler {
  $p -> Name,
  return x  -> return (inl x),
  goto a _  -> return (inr a),
  label _ k -> do c <- !fresh () in
    case k (inl c) of {
      inl x -> return (inl x),
      inr d -> if d == c then k (inr ()) else return (inr d)
    }
} handle (
  effect !label : Unit ~> $p + Unit.
  effect !goto  : $p   ~> Void.

  case !label () of {
    inl a -> case !label () of {
      inl b -> !goto a; return 1,
      inr _ -> return 2
    },
    inr _ -> return 3
  }
)
