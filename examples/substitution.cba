with handler {
  $p -> Name,
  return x  -> return (inl x),
  var a _ -> return (inr a),
  sub _ k -> do c <- !fresh () in
    case k (inl c) of {
      inl x -> return (inl x),
      inr d -> if d == c then k (inr ()) else return (inr d)
    }
} handle (
  effect !sub : Unit ~> $p + Unit.
  effect !var : $p   ~> Void.

  case !sub () of {
    inl a -> case !sub () of {
      inl b -> !var a; return 1,
      inr _ -> return 2
    },
    inr _ -> return 3
  }
)
